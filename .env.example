# Frontend environment variables
# Copy to .env.local for local development

# API base URL - REQUIRED for production deployment
# Set this in your deployment platform (Vercel, Netlify, etc.) to your backend URL
# Examples:
#   - Same domain: https://www.searchlyst.com/api (if /api is proxied to backend)
#   - Separate API: https://api.searchlyst.com/api
VITE_API_BASE_URL=http://localhost:3000/api

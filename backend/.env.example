PORT=3000
# PostgreSQL (production). For local SQLite use: file:./dev.db
DATABASE_URL=postgresql://user:password@localhost:5432/searchlyst
FRONTEND_URL=http://localhost:5173
JWT_SECRET=your-secret-key-change-this-in-production
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=admin@camanahomes.com
SMTP_PASSWORD=your_app_password
NOTIFICATION_EMAIL=krishnasaxena69@gmail.com
NODE_ENV=development

# Welcome email (sent to waitlist signups). Set SEND_WELCOME_EMAIL=false to disable.
# REPLY_TO_EMAIL=hello@searchlyst.com
# COMPANY_ADDRESS=Your physical address for CAN-SPAM (e.g., "123 Main St, City, State ZIP")

# Set ALLOW_ADMIN_SETUP=true only when creating your first admin user, then remove or set to false
ALLOW_ADMIN_SETUP=false
# Optional: Set a SETUP_TOKEN for extra security on the setup route
# If set, you must provide X-Setup-Token header to /api/auth/setup
# SETUP_TOKEN=your_secure_setup_token

# AI Providers
# Gemini API Key (Required for dashboard logic, topics, and analysis)
GEMINI_API_KEY=your_gemini_api_key

# Infatica Web Scraper API (for SEO/AEO/GEO audits, Perplexity AI visibility)
# INFATICA_API_KEY=your_infatica_api_key

# Firecrawl API (for full site audits - multi-page crawl)
# FIRECRAWL_API_KEY=your_firecrawl_api_key
